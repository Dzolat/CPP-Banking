{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++23 MSVC",
      "type": "shell",
      "command": "call \"I:\\VS\\VisualStudioCommunity_2026\\VC\\Auxiliary\\Build\\vcvarsall.bat\" x64 && cl /std:c++latest /EHsc /O2 /permissive- /Fe:\"${workspaceFolder}\\main.exe\" /Fo:\"${workspaceFolder}\\main.obj\" \"${workspaceFolder}\\main.cpp\" && del /q \"${workspaceFolder}\\main.obj\" 2>nul",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}